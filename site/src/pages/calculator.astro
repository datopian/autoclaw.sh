---
import Layout from "../components/Layout.astro";
import "../styles/calculator.css";
import {
  DEFAULT_OUTPUT,
  DEFAULT_PROMPT,
  MODEL_PRICING,
} from "../data/model-pricing";
import { calculateModelCosts, formatUsd } from "../lib/model-cost-calculator";

const initialResults = calculateModelCosts(DEFAULT_PROMPT, DEFAULT_OUTPUT, MODEL_PRICING);
const initialSorted = initialResults.slice().sort((a, b) => a.providerLabel.localeCompare(b.providerLabel));
---

<Layout
  title="Prompt Cost Calculator"
  description="Estimate prompt and response costs across OpenAI, Anthropic, Google, and Cloudflare Workers AI models."
>
  <div class="min-h-screen bg-stone-50 text-zinc-900">
    <div class="grid gap-6">

      <section class="rounded-[28px] border border-zinc-200 bg-white p-6 shadow-sm">
        <h1 class="text-4xl font-semibold tracking-[-0.06em] text-zinc-950 sm:text-6xl">
          Compare prompt costs across multiple models.
        </h1>
        <p class="mt-4 text-base leading-7 text-zinc-600">
          Drop in the prompt you want to send and a representative response. The calculator
          estimates input and output usage, then ranks providers by expected cost.
        </p>
      </section>

      <section class="grid gap-6">
        <div class="rounded-[24px] border border-zinc-200 bg-white p-5 shadow-sm">
          <div class="grid gap-5 lg:grid-cols-2">
            <label class="grid gap-2">
              <span class="font-mono text-xs uppercase tracking-[0.18em] text-zinc-600">
                Input prompt
              </span>
              <textarea
                id="promptInput"
                class="min-h-48 rounded-2xl border border-zinc-300 bg-white px-4 py-4 text-base leading-7 text-zinc-900 outline-none transition focus:border-zinc-900 focus:ring-4 focus:ring-zinc-900/5"
              >{DEFAULT_PROMPT}</textarea>
            </label>

            <label class="grid gap-2">
              <span class="font-mono text-xs uppercase tracking-[0.18em] text-zinc-600">
                Model output
              </span>
              <textarea
                id="outputInput"
                class="min-h-48 rounded-2xl border border-zinc-300 bg-white px-4 py-4 text-base leading-7 text-zinc-900 outline-none transition focus:border-zinc-900 focus:ring-4 focus:ring-zinc-900/5"
              >{DEFAULT_OUTPUT}</textarea>
            </label>
          </div>

          <p class="mt-5 border-t border-zinc-200 pt-4 text-sm leading-6 text-zinc-600">
            Token counts are estimated using the rule of thumb of{" "}
            <span class="font-medium text-zinc-900">1 token ≈ 4 characters</span>, as
            documented by{" "}
            <a
              href="https://help.openai.com/en/articles/4936856-what-are-tokens-and-how-to-count-them"
              target="_blank"
              rel="noreferrer"
              class="font-medium text-zinc-900 underline underline-offset-2 hover:text-red-700"
            >OpenAI</a>
            {" "}and{" "}
            <a
              href="https://ai.google.dev/gemini-api/docs/tokens"
              target="_blank"
              rel="noreferrer"
              class="font-medium text-zinc-900 underline underline-offset-2 hover:text-red-700"
            >Google</a>.
            Costs are directional estimates for comparing providers, not billing-grade figures.
          </p>
        </div>

        <div class="rounded-[24px] border border-zinc-200 bg-white p-5 shadow-sm">
          <div class="mb-4 flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
            <div>
              <p class="font-mono text-xs uppercase tracking-[0.18em] text-amber-800">
                Cost Comparison
              </p>
              <h2 class="mt-1 text-2xl font-semibold tracking-[-0.04em] text-zinc-950">
                Estimated cost per model
              </h2>
            </div>
            <p id="sortMeta" class="text-sm text-zinc-500">Sorted by provider · click any column to sort</p>
          </div>

          <div class="overflow-visible rounded-2xl border border-zinc-200">
            <div class="overflow-x-auto overflow-y-visible">
              <table class="w-full min-w-[900px] border-collapse bg-white">
                <thead class="bg-zinc-50">
                  <tr>
                    <th class="px-4 py-3 text-left font-mono text-[11px] uppercase tracking-[0.18em] text-zinc-500">
                      Compare
                    </th>
                    {[
                      { label: "Provider", key: "providerLabel" },
                      { label: "Model", key: "modelLabel" },
                      { label: "Input $/1M", key: "inputCostPerMillionUsd" },
                      { label: "Output $/1M", key: "outputCostPerMillionUsd" },
                      { label: "Input Cost", key: "inputCostUsd" },
                      { label: "Output Cost", key: "outputCostUsd" },
                      { label: "Total", key: "totalCostUsd" },
                    ].map(({ label, key }) => (
                      <th
                        data-sort-key={key}
                        class="cursor-pointer select-none px-4 py-3 text-left font-mono text-[11px] uppercase tracking-[0.18em] text-zinc-500 hover:text-zinc-900"
                      >
                        <span class="inline-flex items-center gap-1">
                          {label}
                          <span data-sort-icon={key} class="text-zinc-300 text-[10px]">↑</span>
                        </span>
                      </th>
                    ))}
                  </tr>
                </thead>
                <tbody id="calculatorTableBody">
                  {initialSorted.map((result, index) => (
                    <tr class={index % 2 === 0 ? "bg-white" : "bg-zinc-50/60"}>
                      <td class="border-t border-zinc-200 px-4 py-3 text-center">
                        <input
                          type="checkbox"
                          data-model-id={result.modelId}
                          class="h-4 w-4 cursor-pointer rounded border-zinc-300 accent-amber-600"
                        />
                      </td>
                      <td class="border-t border-zinc-200 px-4 py-3 text-sm text-zinc-700">
                        {result.providerLabel}
                      </td>
                      <td class="border-t border-zinc-200 px-4 py-3 text-sm font-medium text-zinc-950">
                        {result.modelLabel}
                      </td>
                      <td class="border-t border-zinc-200 px-4 py-3 text-sm text-zinc-700">
                        ${result.inputCostPerMillionUsd.toFixed(2)}/1M
                      </td>
                      <td class="border-t border-zinc-200 px-4 py-3 text-sm text-zinc-700">
                        ${result.outputCostPerMillionUsd.toFixed(2)}/1M
                      </td>
                      <td class="border-t border-zinc-200 px-4 py-3 text-sm text-zinc-700">
                        <div>~{formatUsd(result.inputCostUsd)}</div>
                        <div class="mt-0.5 text-xs text-zinc-400">
                          ~{result.inputTokens.toLocaleString("en-US")} tokens
                        </div>
                      </td>
                      <td class="border-t border-zinc-200 px-4 py-3 text-sm text-zinc-700">
                        <div>~{formatUsd(result.outputCostUsd)}</div>
                        <div class="mt-0.5 text-xs text-zinc-400">
                          ~{result.outputTokens.toLocaleString("en-US")} tokens
                        </div>
                      </td>
                      <td class="border-t border-zinc-200 px-4 py-3 text-sm font-semibold text-zinc-950">
                        ~{formatUsd(result.totalCostUsd)}
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </section>

    </div>
  </div>

  <script define:vars={{ MODEL_PRICING }}>
    const TOKENS_PER_MILLION = 1_000_000;
    const CHARS_PER_TOKEN = 4;

    const promptInput = document.getElementById('promptInput');
    const outputInput = document.getElementById('outputInput');
    const tableBody = document.getElementById('calculatorTableBody');
    const sortMeta = document.getElementById('sortMeta');

    let sortKey = 'providerLabel';
    let sortDirection = 'asc';
    const pinnedIds = new Set();

    const countTokens = (text) =>
      text.length === 0 ? 0 : Math.ceil(text.length / CHARS_PER_TOKEN);

    const formatUsd = (value) =>
      new Intl.NumberFormat('en-US', {
        style: 'currency',
        currency: 'USD',
        minimumFractionDigits: 6,
        maximumFractionDigits: 6,
      }).format(value);

    const calculateModelCosts = (prompt, output) =>
      MODEL_PRICING.map((model) => {
        const inputTokens = countTokens(prompt);
        const outputTokens = countTokens(output);
        const inputCostUsd = (inputTokens * model.inputCostPerMillionUsd) / TOKENS_PER_MILLION;
        const outputCostUsd = (outputTokens * model.outputCostPerMillionUsd) / TOKENS_PER_MILLION;
        return {
          ...model,
          inputTokens,
          outputTokens,
          inputCostUsd,
          outputCostUsd,
          totalCostUsd: inputCostUsd + outputCostUsd,
        };
      });

    const sortResults = (results) =>
      [...results].sort((a, b) => {
        const aVal = a[sortKey];
        const bVal = b[sortKey];
        const cmp = typeof aVal === 'string' ? aVal.localeCompare(bVal) : aVal - bVal;
        return sortDirection === 'asc' ? cmp : -cmp;
      });

    const updateSortIndicators = () => {
      document.querySelectorAll('[data-sort-icon]').forEach((el) => {
        const key = el.dataset.sortIcon;
        if (key === sortKey) {
          el.textContent = sortDirection === 'asc' ? '↑' : '↓';
          el.classList.remove('text-zinc-300');
          el.classList.add('text-zinc-900');
        } else {
          el.textContent = '↑';
          el.classList.remove('text-zinc-900');
          el.classList.add('text-zinc-300');
        }
      });
      if (sortMeta) {
        const label = document.querySelector(`[data-sort-key="${sortKey}"]`)?.querySelector('[data-sort-icon]')?.closest('th')?.textContent?.trim() ?? sortKey;
        sortMeta.textContent = `Sorted by ${label.toLowerCase()} ${sortDirection === 'asc' ? '↑' : '↓'} · click any column to sort`;
      }
    };

    const renderRows = () => {
      if (!(promptInput instanceof HTMLTextAreaElement) ||
          !(outputInput instanceof HTMLTextAreaElement) ||
          !(tableBody instanceof HTMLTableSectionElement)) return;

      const results = calculateModelCosts(promptInput.value, outputInput.value);
      const sorted = sortResults(results);
      const pinned = sorted.filter((r) => pinnedIds.has(r.modelId));
      const rest = sorted.filter((r) => !pinnedIds.has(r.modelId));

      tableBody.innerHTML = [...pinned, ...rest].map((result, index) => {
        const isPinned = pinnedIds.has(result.modelId);
        const rowClass = isPinned
          ? 'border-l-2 border-l-amber-400 bg-amber-50/60'
          : index % 2 === 0 ? 'bg-white' : 'bg-zinc-50/60';
        return `
          <tr class="${rowClass}">
            <td class="border-t border-zinc-200 px-4 py-3 text-center">
              <input
                type="checkbox"
                data-model-id="${result.modelId}"
                class="h-4 w-4 cursor-pointer rounded border-zinc-300 accent-amber-600"
                ${isPinned ? 'checked' : ''}
              />
            </td>
            <td class="border-t border-zinc-200 px-4 py-3 text-sm text-zinc-700">${result.providerLabel}</td>
            <td class="border-t border-zinc-200 px-4 py-3 text-sm font-medium text-zinc-950">${result.modelLabel}</td>
            <td class="border-t border-zinc-200 px-4 py-3 text-sm text-zinc-700">$${result.inputCostPerMillionUsd.toFixed(2)}/1M</td>
            <td class="border-t border-zinc-200 px-4 py-3 text-sm text-zinc-700">$${result.outputCostPerMillionUsd.toFixed(2)}/1M</td>
            <td class="border-t border-zinc-200 px-4 py-3 text-sm text-zinc-700">
              <div>~${formatUsd(result.inputCostUsd)}</div>
              <div class="mt-0.5 text-xs text-zinc-400">~${result.inputTokens.toLocaleString('en-US')} tokens</div>
            </td>
            <td class="border-t border-zinc-200 px-4 py-3 text-sm text-zinc-700">
              <div>~${formatUsd(result.outputCostUsd)}</div>
              <div class="mt-0.5 text-xs text-zinc-400">~${result.outputTokens.toLocaleString('en-US')} tokens</div>
            </td>
            <td class="border-t border-zinc-200 px-4 py-3 text-sm font-semibold text-zinc-950">~${formatUsd(result.totalCostUsd)}</td>
          </tr>
        `;
      }).join('');

      attachCheckboxListeners();
    };

    const attachCheckboxListeners = () => {
      tableBody.querySelectorAll('[data-model-id]').forEach((cb) => {
        cb.addEventListener('change', (e) => {
          const modelId = e.target.dataset.modelId;
          if (e.target.checked) pinnedIds.add(modelId);
          else pinnedIds.delete(modelId);
          renderRows();
        });
      });
    };

    // Attach listeners to the server-rendered initial rows
    attachCheckboxListeners();

    document.querySelectorAll('[data-sort-key]').forEach((th) => {
      th.addEventListener('click', () => {
        const key = th.dataset.sortKey;
        if (key === sortKey) sortDirection = sortDirection === 'asc' ? 'desc' : 'asc';
        else { sortKey = key; sortDirection = 'asc'; }
        updateSortIndicators();
        renderRows();
      });
    });

    promptInput?.addEventListener('input', renderRows);
    outputInput?.addEventListener('input', renderRows);
  </script>
</Layout>
