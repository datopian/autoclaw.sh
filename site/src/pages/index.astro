---
import Layout from '../components/Layout.astro';

const GITHUB_URL = 'https://github.com/datopian/autoclaw.sh';

const signals = [
  {
    label: 'Open by Default',
    detail:
      'MIT licensed. Every playbook, template, and reference implementation is public. We build in the open so you can see exactly how production agent systems are structured.',
  },
  {
    label: 'Batteries Included',
    detail:
      'Clone a template and have a working agent deployment in minutes. Reference implementations cover common patterns: memory, tool use, multi-channel routing, and more.',
  },
  {
    label: 'Production Patterns',
    detail:
      'Not toy examples. These are the patterns we use running real agents: durable state, queue-backed execution, sandboxed containers, and observable operations.',
  },
];

const steps = [
  'Fork an example or clone a template that matches your use case.',
  'Swap in your model, tools, and channels — the framework handles the rest.',
  'Deploy on Cloudflare Workers. Contribute patterns back.',
];
---

<Layout title="Open Framework for AI Agent Deployment" description="An open framework for building and operating AI agent systems. Playbooks, templates, and reference implementations — all public, all production-grade.">
  <section class="landingHero">
    <div class="landingHeroCopy">
      <p class="landingKicker">For OpenClaw</p>
      <h1 class="landingTitle">
        Deploy OpenClaw.<br />
        Do it right.
      </h1>
      <p class="landingLead">
        The open deployment reference for OpenClaw AI agents.<br />
        Playbooks, templates, and reference implementations.
      </p>
      <div class="actions landingActions">
        <a href={GITHUB_URL} class="button landingButton" target="_blank" rel="noopener">
          ★ Star on GitHub
        </a>
        <a href="/playbooks" class="button landingGhostButton">
          Read the Playbooks
        </a>
      </div>
    </div>
    <div class="landingHeroRail">
      <figure class="landingHeroVisual">
        <img src="/brand/hero-visual.png" alt="AutoClaw agent architecture" width="600" height="400" />
      </figure>
    </div>
  </section>

  <section class="landingSignals" aria-label="Why AutoClaw">
    {signals.map((item) => (
      <article class="landingSignalRow">
        <h2>{item.label}</h2>
        <p>{item.detail}</p>
      </article>
    ))}
  </section>

  <section class="landingFlow" aria-label="How to get started">
    <h2>How it works</h2>
    <ol>
      {steps.map((step) => (
        <li>{step}</li>
      ))}
    </ol>
  </section>
</Layout>
