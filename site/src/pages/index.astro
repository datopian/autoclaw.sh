---
import { getCollection } from 'astro:content';
import Layout from '../components/Layout.astro';

const GITHUB_URL = 'https://github.com/datopian/autoclaw.sh';

const playbooks = (await getCollection('playbooks', ({ data }) => !data.draft))
  .sort((a, b) => a.id.localeCompare(b.id));

const examples = await getCollection('examples', ({ data }) => !data.draft);
const exampleItems = examples
  .sort((a, b) => a.id.localeCompare(b.id))
  .map((entry) => ({ entry, slug: entry.id.split('/')[0] }));
---

<Layout title="Open Source Deploy for OpenClaw" description="Skills, playbooks, templates, and tutorials to help you deploy OpenClaw and other agents.">
  <section class="landingHero">
    <div class="landingHeroCopy">
      <h1 class="landingTitle">
        Open Source Deploy<br />
        for OpenClaw.
      </h1>
      <p class="landingLead">
        Skills, playbooks, templates, and tutorials to help you deploy OpenClaw and other agents.
      </p>
      <p class="landingLead landingLeadSpice">
        We prototyped a SaaS for OpenClaw and decided to open source everything we learned.
      </p>
      <form class="heroCta" id="ctaForm" novalidate>
        <p class="heroCtaHeadline">What we're building, breaking, and shipping.</p>
        <div class="heroCtaInputRow">
          <input
            class="heroCtaInput"
            id="ctaEmail"
            type="email"
            name="email"
            placeholder="you@company.com"
            autocomplete="email"
          />
          <button type="submit" class="heroCtaButton" id="ctaBtn">Stay in the loop</button>
        </div>
        <p class="heroCtaNote" id="ctaNote">We email when we ship something. Roughly once a month.</p>
      </form>

      <script>
        const form = document.getElementById('ctaForm') as HTMLFormElement;
        const input = document.getElementById('ctaEmail') as HTMLInputElement;
        const btn = document.getElementById('ctaBtn') as HTMLButtonElement;
        const note = document.getElementById('ctaNote') as HTMLParagraphElement;

        form.addEventListener('submit', async (e) => {
          e.preventDefault();
          const email = input.value.trim();
          if (!email) return;

          btn.disabled = true;
          btn.textContent = 'Sending…';

          try {
            const res = await fetch('/subscribe', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ email }),
            });

            if (res.ok) {
              input.value = '';
              btn.textContent = 'You\'re in ✓';
              note.textContent = 'Check your inbox soon.';
              note.style.color = 'var(--success)';
            } else {
              btn.textContent = 'Try again';
              btn.disabled = false;
              note.textContent = 'Something went wrong. Try again.';
              note.style.color = '#b91c1c';
            }
          } catch {
            btn.textContent = 'Try again';
            btn.disabled = false;
            note.textContent = 'Network error. Try again.';
            note.style.color = '#b91c1c';
          }
        });
      </script>
      <a href={GITHUB_URL} class="githubLink" target="_blank" rel="noopener">
        ★ Star on GitHub
      </a>
    </div>
    <div class="landingHeroRail">
      <figure class="landingHeroVisual">
        <img src="/brand/hero-visual.png" alt="AutoClaw agent architecture" width="600" height="400" />
      </figure>
    </div>
  </section>

  <section class="landingSignals" aria-label="Playbooks">
    <div class="landingSignalRow">
      <h2><a href="/playbooks" class="landingSectionLink">Playbooks</a></h2>
      <div>
        {playbooks.length === 0 ? (
          <p style="color: var(--text-muted);">Coming soon.</p>
        ) : (
          <div class="contentList">
            {playbooks.map((entry) => (
              <a href={`/playbooks/${entry.id}`} class="contentCard">
                <h2>{entry.data.title ?? entry.id}</h2>
                {entry.data.description && <p>{entry.data.description}</p>}
              </a>
            ))}
          </div>
        )}
      </div>
    </div>
    <div class="landingSignalRow">
      <h2><a href="/examples" class="landingSectionLink">Examples</a></h2>
      <div>
        {exampleItems.length === 0 ? (
          <p style="color: var(--text-muted);">Coming soon.</p>
        ) : (
          <div class="contentList">
            {exampleItems.map(({ entry, slug }) => (
              <a href={`/examples/${slug}`} class="contentCard">
                <h2>{entry.data.title ?? slug}</h2>
                {entry.data.description && <p>{entry.data.description}</p>}
              </a>
            ))}
          </div>
        )}
      </div>
    </div>
    <div class="landingSignalRow contactRow">
      <h2>Work with us</h2>
      <div>
        <p class="contactBlurb">Need help deploying OpenClaw in production? We offer consulting and professional services.</p>
        <a href="mailto:contact@datopian.com?subject=Interested%20in%20Autoclaw%20services" class="contactLink">contact@datopian.com</a>
      </div>
    </div>
  </section>
</Layout>
