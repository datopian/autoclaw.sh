      posthog.init('phc_sXJQxMYrqtBVCX5wLKGLmvJwBtMMdWoSzfscVUWHkx5d', {
        api_host: 'https://t.autoclaw.sh',
        ui_host: 'https://eu.posthog.com',
        defaults: '2026-01-30',
        person_profiles: 'identified_only',
      });
    </script>
  </head>
  <body>
    <main class="landingMain">
      <header class="landingTopbar">
        <a href="/" class="landingBrand">
          <span class="brandMark"></span>
          AutoClaw
        </a>

        <button
          type="button"
          class="landingMenuButton"
          aria-label="Toggle navigation menu"
          aria-expanded="false"
          id="menuBtn"
        >
          <span></span>
          <span></span>
          <span></span>
        </button>

        <nav class="landingNavLinks" id="navLinks">
          <a href="/playbooks" class="landingNavLink">Playbooks</a>
          <a href="/examples" class="landingNavLink">Examples</a>
          <a href="/blog" class="landingNavLink">Blog</a>
          <a href={GITHUB_URL} class="landingNavLink" target="_blank" rel="noopener">GitHub</a>
        </nav>
      </header>

      <slot />

      <footer class="footer landingFooter">
        <span>The open deployment reference for OpenClaw agents. Made by Datopian.</span>
        <nav class="footerLinks">
          <a href="/playbooks">Playbooks</a>
          <a href="/examples">Examples</a>
          <a href="/blog">Blog</a>
          <a href={GITHUB_URL} target="_blank" rel="noopener">GitHub</a>
        </nav>
      </footer>
    </main>

    <script>
      const btn = document.getElementById('menuBtn');
      const nav = document.getElementById('navLinks');
      btn?.addEventListener('click', () => {
        const open = btn.classList.toggle('isOpen');
        nav?.classList.toggle('isOpen', open);
        btn.setAttribute('aria-expanded', String(open));
      });
      window.addEventListener('resize', () => {
        if (window.innerWidth > 680) {
          btn?.classList.remove('isOpen');
          nav?.classList.remove('isOpen');
          btn?.setAttribute('aria-expanded', 'false');
        }
      });
    </script>
  </body>
</html>
