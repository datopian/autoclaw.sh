{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "openclaw-worker-api",
	"account_id": "YOUR_CLOUDFLARE_ACCOUNT_ID",
	"main": "src/index.ts",
	"compatibility_date": "2026-02-08",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"vars": {
		"APP_ENV": "dev",
		"MEMORY_RETENTION_DAYS": "90",
		"OPENCLAW_SANDBOX_SLEEP_AFTER": "2h",
		"CF_ACCOUNT_ID": "YOUR_CLOUDFLARE_ACCOUNT_ID",
		"AI_GATEWAY_ID": "openclaw-gateway-prod",
		"DEFAULT_MODEL_PROVIDER": "openai",
		"DEFAULT_MODEL_ID": "gpt-4o-mini",
		"TELEGRAM_RUNTIME_MODE": "openclaw_runtime",
		"TELEGRAM_RUNTIME_ALLOWLIST": "",
		"TELEGRAM_RUNTIME_FALLBACK_DIRECT": "0"
	},
	"triggers": {
		"crons": [
			"0 * * * *"
		]
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "openclaw_aaas",
			"database_id": "YOUR_D1_DATABASE_ID",
			"remote": true
		}
	],
	"r2_buckets": [
		{
			"binding": "ARTIFACTS",
			"bucket_name": "openclaw-artifacts",
			"remote": true
		}
	],
	"ai": {
		"binding": "AI"
	},
	"queues": {
		"producers": [
			{
				"binding": "RUN_QUEUE",
				"queue": "openclaw-runs"
			},
			{
				"binding": "MEMORY_INGEST_QUEUE",
				"queue": "openclaw-memory-ingest"
			},
			{
				"binding": "MEMORY_DISTILL_QUEUE",
				"queue": "openclaw-memory-distill"
			}
		],
		"consumers": [
			{
				"queue": "openclaw-runs"
			},
			{
				"queue": "openclaw-memory-ingest",
				"max_retries": 10,
				"dead_letter_queue": "openclaw-memory-ingest-dead"
			},
			{
				"queue": "openclaw-memory-distill",
				"max_retries": 10,
				"dead_letter_queue": "openclaw-memory-distill-dead"
			}
		]
	},
	"durable_objects": {
		"bindings": [
			{
				"name": "AGENT_SESSION",
				"class_name": "AgentSession"
			},
			{
				"name": "Sandbox",
				"class_name": "TenantSandbox"
			}
		]
	},
	"containers": [
		{
			"class_name": "TenantSandbox",
			"image": "./runtime/Dockerfile",
			"instance_type": "standard-1",
			"max_instances": 50
		}
	],
	"migrations": [
		{
			"tag": "v1",
			"new_sqlite_classes": [
				"AgentSession"
			]
		},
		{
			"tag": "v2",
			"new_sqlite_classes": [
				"TenantSandbox"
			]
		}
	]
}
